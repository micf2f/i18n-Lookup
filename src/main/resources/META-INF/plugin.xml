<idea-plugin>
    <id>com.github.micf2f.i18nlookup</id>
    <name>i18n-Lookup</name>
    <vendor email="micf2f@gmail.com" url="https://github.com/micf2f/i18n-Lookup">micf2f</vendor>
    <description><![CDATA[
        <p><b>i18n-Lookup</b> shows your translations right where you use them.</p>
        <ul>
            <li>Hover over an i18n key such as <code>t('key')</code>, <code>i18n.t('key')</code>,
                <code>$t('key')</code>, <code>translate('key')</code> (or your own regex) to see the
                translation from your chosen language file.</li>
            <li>Point it at a single JSON file for one language, or at a folder of JSON files to see
                every language at once &mdash; one row per file, with long lists scrolling inside the popup.</li>
            <li>Add an optional second source (another file or folder) to look up translations from both
                at once &mdash; when a key lives in both, each source's value is shown grouped under its path.</li>
            <li>Click a language in the popup to jump straight to that key in its JSON file.</li>
        </ul>
        <p>Configure the translation file or folder and recognized formats in
            <b>Settings | Tools | i18n Lookup</b>.</p>
        <p>Works in any IDE that bundles JavaScript support: WebStorm, PhpStorm, IntelliJ IDEA
            Ultimate, PyCharm Professional, GoLand, RubyMine, Rider, and more.</p>
    ]]></description>

    <depends>com.intellij.modules.platform</depends>
    <depends>JavaScript</depends>
    <depends>com.intellij.modules.json</depends>

    <resource-bundle>messages.MyBundle</resource-bundle>

    <extensions defaultExtensionNs="com.intellij">
        <projectConfigurable
            parentId="tools"
            id="com.github.micf2f.i18nlookup.settings.I18nSettingsConfigurable"
            instance="com.github.micf2f.i18nlookup.settings.I18nSettingsConfigurable"
            displayName="i18n Lookup"/>

        <externalAnnotator
            language="JavaScript"
            implementationClass="com.github.micf2f.i18nlookup.hover.I18nExternalAnnotator"/>
        <externalAnnotator
            language="TypeScript"
            implementationClass="com.github.micf2f.i18nlookup.hover.I18nExternalAnnotator"/>

        <platform.backend.documentation.targetProvider
            implementation="com.github.micf2f.i18nlookup.hover.I18nDocumentationTargetProvider"/>
        <platform.backend.documentation.linkHandler
            implementation="com.github.micf2f.i18nlookup.hover.I18nDocumentationLinkHandler"/>

        <codeInsight.declarativeInlayProvider
            language="JavaScript"
            implementationClass="com.github.micf2f.i18nlookup.hover.I18nInlayHintsProvider"
            isEnabledByDefault="true"
            group="VALUES_GROUP"
            providerId="i18n.lookup.inline"
            bundle="messages.MyBundle"
            nameKey="inlay.i18nLookup.name"
            descriptionKey="inlay.i18nLookup.description"/>
        <codeInsight.declarativeInlayProvider
            language="TypeScript"
            implementationClass="com.github.micf2f.i18nlookup.hover.I18nInlayHintsProvider"
            isEnabledByDefault="true"
            group="VALUES_GROUP"
            providerId="i18n.lookup.inline"
            bundle="messages.MyBundle"
            nameKey="inlay.i18nLookup.name"
            descriptionKey="inlay.i18nLookup.description"/>
        <codeInsight.inlayActionHandler
            handlerId="i18n-lookup.goto"
            implementationClass="com.github.micf2f.i18nlookup.hover.I18nInlayActionHandler"/>
    </extensions>
</idea-plugin>
